# Directory that is scanned for apps (each subfolder with a .virtualx.<app> marker file).
APPS_DIR=/var/virtualx/apps

# Where the whitelist config is stored/read from.
WHITELIST_PATH=config/apps.json

# WhatsApp notifications (Baileys)
# Target number in international format, digits only or with + prefix, e.g. 491234567890
WHATSAPP_TARGET_NUMBER=
# Directory used to persist the paired WhatsApp session (multi-file auth state).
WHATSAPP_AUTH_DIR=.baileys_auth

# Deploy target
# srv010's public hostname only offers GSSAPI auth for root; use the internal
# LAN IP from dev001 (the control host), where key-based SSH works.
DEPLOY_HOST=root@192.168.0.10
DEPLOY_REMOTE_PATH=/var/virtualx/apps
# Optional path to a private key if not using the default SSH identity/agent.
DEPLOY_SSH_KEY=
