        "repo": "phpmyadmin/phpmyadmin",
        "tagPattern": "RELEASE_(\\d+)_(\\d+)_(\\d+)$"
      }
    },
    {
      "folder": "_archive/magento24",
      "name": "Magento",
      "enabled": false
    },
    {
