        "type": "github-tag",
        "repo": "roundcube/roundcubemail",
        "tagPattern": "^v?(\\d+)\\.(\\d+)\\.(\\d+)$"
      }
    },
    {
      "folder": "_archive/opencart",
      "name": "OpenCart",
      "enabled": false
    },
    {
      "folder": "_archive/phpBB3",
      "name": "phpBB3",
      "enabled": false
    },
    {
      "folder": "_instances/typo3",
      "name": "TYPO3",
